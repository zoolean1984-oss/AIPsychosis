/* ---------------------------
UI RENDER
----------------------------*/

const container=document.getElementById("checklists");

symptoms.forEach((s,i)=>{
 const div=document.createElement("div");
 div.className="item";

 const cb=document.createElement("input");
 cb.type="checkbox";
 cb.id="sym"+i;

 const label=document.createElement("label");
 label.htmlFor=cb.id;
 label.textContent=s.symptom;

 div.appendChild(cb);
 div.appendChild(label);
 container.appendChild(div);
});

/* ---------------------------
EVALUATION
----------------------------*/

document.getElementById("submitBtn").onclick=()=>{

const counts={};

Object.keys(disorderThresholds).forEach(d=>counts[d]=0);

symptoms.forEach((s,i)=>{
 if(document.getElementById("sym"+i).checked){
  s.conditions.forEach(c=>{
    counts[c]++
  })
 }
});

const results=document.getElementById("results");
results.innerHTML="";

Object.entries(counts).forEach(([d,c])=>{
 if(c>=disorderThresholds[d]){
   results.innerHTML+=`<div>${d} </div>`;
 }
});

if(results.innerHTML===""){
 results.textContent="No disorder thresholds met.";
}

document.getElementById("resultsModal").style.display="block";

};

document.getElementById("closeModal").onclick=()=>{

document.getElementById("resultsModal").style.display="none"

};

window.onclick=e=>{
 if(e.target==document.getElementById("resultsModal")){
  document.getElementById("resultsModal").style.display="none"
 }
};

